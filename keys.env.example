# PolyArb v3 — Configuration
# Copy this file to keys.env and fill in your values

# Your Polymarket private key (0x...)
PK=YOUR_PRIVATE_KEY_HERE

# Your proxy wallet address (0x...)
PROXY_WALLET=YOUR_PROXY_WALLET_HERE

# ── Strategy Parameters ────────────────────────────────
# Bankroll in USDC
BANKROLL=1000

# Enter a market if YES_ask + NO_ask < this (1.0 = no arb, 0.97 = 3% spread)
ENTRY_THRESHOLD=0.97

# Minimum spread % to bother entering
MIN_SPREAD_PCT=2.5

# Base trade size in USDC per side (scales up with spread and harvest mode)
BASE_TRADE_SIZE=5.0

# Max trade size per side per fill
MAX_TRADE_SIZE=50.0

# Max total USDC deployed per market (across all fills)
MAX_POSITION=500

# Seconds between market scans
SCAN_INTERVAL=5.0

# Max markets to fetch per scan
MAX_MARKETS=200

# Cancel stale limit orders after this many seconds
ORDER_EXPIRY=120

# Trigger harvest mode (scale up) when one side crosses this price
HARVEST_THRESHOLD=0.85
